{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
   "permissions": {
    "allow": [
      "Bash(command -v:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir -p:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(python server.py:*)",
      "Bash(node --check:*)",
      "Bash(node tests/app.test.js:*)",
      "Bash(node tests/run_ui.mjs:*)",
      "Bash(python tests/server_test.py:*)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -sL -o vendor/*)",
      "mcp__Claude_Preview__preview_start"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push:*)",
      "Bash(curl:*)",
      "Bash(python -c:*)"
    ]
  }
}
