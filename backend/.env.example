# Copy to .env for local overrides. All values optional in dev.

# Unset = local SQLite dev.db (offline, no Postgres needed).
# Prod (Render): Neon POOLED connection string, e.g.
#   postgresql+asyncpg://user:pass@ep-xxx-pooler.region.aws.neon.tech/momentum?ssl=require
DATABASE_URL=

# Comma-separated exact origins allowed by CORS.
# Prod: your Vercel URL, e.g. https://momentum-xyz.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

ENV=development
SESSION_TTL_DAYS=30
MAX_BODY_BYTES=2097152
# Set to 1 (with a built frontend/dist) for single-origin smoke tests.
SERVE_STATIC=0

# -- Email verification -------------------------------------------------
# Unset = dev mode: verification codes are logged (and written to
# .dev_codes.json) instead of emailed, so local runs need no provider.
# Prod: a Resend API key (https://resend.com), and a verified sender.
RESEND_API_KEY=
EMAIL_FROM=Momentum <onboarding@resend.dev>
EMAIL_FROM_NAME=Momentum
# Strong random secret for HMAC-hashing verification codes. REQUIRED in prod
# (generate e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`).
VERIFICATION_SECRET=
VERIFICATION_CODE_TTL_MINUTES=15
VERIFICATION_MAX_ATTEMPTS=5
