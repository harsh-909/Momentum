# Copy to .env for local overrides. All values optional in dev.

# Unset = local SQLite dev.db (offline, no Postgres needed).
# Set = the app runs on that database (e.g. Neon) locally too.
# Paste the Neon POOLED string verbatim - the app normalizes the driver prefix
# and the sslmode/channel_binding params automatically, e.g.
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/momentum?sslmode=require&channel_binding=require
DATABASE_URL=

# Optional: direct (non-pooled) Neon string, used ONLY by Alembic migrations.
# Unset = migrations reuse DATABASE_URL. Paste the non-pooler string verbatim.
MIGRATIONS_DATABASE_URL=

# Comma-separated exact origins allowed by CORS.
# Prod: your Vercel URL, e.g. https://momentum-xyz.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

ENV=development
SESSION_TTL_DAYS=30
MAX_BODY_BYTES=2097152
# Set to 1 (with a built frontend/dist) for single-origin smoke tests.
SERVE_STATIC=0
