# Copy to .env for local overrides. All values optional in dev.

# Unset = local SQLite dev.db (offline, no Postgres needed).
# Prod (Render): Neon POOLED connection string, e.g.
#   postgresql+asyncpg://user:pass@ep-xxx-pooler.region.aws.neon.tech/momentum?ssl=require
DATABASE_URL=

# Comma-separated exact origins allowed by CORS.
# Prod: your Vercel URL, e.g. https://momentum-xyz.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

ENV=development
SESSION_TTL_DAYS=30
MAX_BODY_BYTES=2097152
# Set to 1 (with a built frontend/dist) for single-origin smoke tests.
SERVE_STATIC=0
